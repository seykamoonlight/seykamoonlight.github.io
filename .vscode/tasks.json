{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "photo/ — Start Server",
      "type": "shell",
      "command": "python3 server.py",
      "options": { "cwd": "${workspaceFolder}/photo" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "photo/ — Open Editor",
      "type": "shell",
      "command": "open http://localhost:8000/editor.html",
      "presentation": { "reveal": "never", "panel": "new", "close": true },
      "problemMatcher": []
    },
    {
      "label": "photo/ — Open Viewer",
      "type": "shell",
      "command": "open http://localhost:8000/",
      "presentation": { "reveal": "never", "panel": "new", "close": true },
      "problemMatcher": []
    },
    {
      "label": "Publier sur gh-pages",
      "type": "shell",
      "command": "bash publish.sh",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    }
  ]
}
